{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist/server",
    "rootDir": "src"
  },
  "include": [
    "src/contracts/**/*.ts",
    "src/shared/**/*.ts",
    "src/domain/**/*.ts",
    "src/infra/**/*.ts",
    "src/runner/**/*.ts",
    "src/services/**/*.ts",
    "src/server/**/*.ts",
    "src/index.ts"
  ]
}
