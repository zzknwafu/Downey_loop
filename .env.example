# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# App
APP_NAME=Downey Evals Loop
APP_BASE_URL=http://localhost:3000

# Gemini
# Add your real key in .env on the server. Do not commit it.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Optional compatibility fallback for older environments
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Storage
DATA_DIR=./data
STORE_FILE=downey-evals-store.json
# Local state is stored at $DATA_DIR/app-state.json.
# SQLITE_PATH is reserved for the future SQLite adapter and is surfaced in config metadata.
SQLITE_PATH=./data/downey-evals-loop.sqlite
